# WalkTogether Backend Environment Variables
# Copy this file to .env and adjust values as needed.
# Do NOT commit the real .env file.

# Server port (must match Flutter app's API_BASE_URL)
PORT=3000

# OTP configuration
# Dev mode: OTP is always 123456 for all phone numbers
OTP_PROVIDER=dev
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5

# Session secret (change for production)
SESSION_SECRET=walktogether-dev-secret-change-me

# Production OTP providers (leave commented for dev mode)
# OTP_PROVIDER=msg91
# OTP_API_KEY=your-msg91-authkey
# OTP_SENDER_ID=WALKTG
# OTP_TEMPLATE_ID=your-msg91-template-id

# OTP_PROVIDER=twilio
# OTP_AUTH_TOKEN=your-twilio-auth-token

# Free product promise — never change this
IS_FREE_PRODUCT=true
